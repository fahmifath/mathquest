model AiRecommendation {
  id                   String   @id @default(uuid())
  userId               String   @map("user_id")
  pretestSessionId     String   @unique @map("pretest_session_id")
  recommendedModuleId   String   @map("recommended_module_id")
  confidence Float

  createdAt DateTime @default(now()) @map("created_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pretestSession PretestSession @relation(fields: [pretestSessionId], references: [id], onDelete: Cascade)
  module  Module         @relation(fields: [recommendedModuleId], references: [id])

  @@index([userId])
  @@index([pretestSessionId])
  @@map("ai_recommendations")
}
